{
  "name": "granum",
  "version": "0.1.0",
  "description": "Persistent semantic memory for Claude Code sessions",
  "mcp": ".mcp.json",
  "hooks": {
    "UserPromptSubmit": "hooks/granum-log.sh",
    "Stop": "hooks/granum-compact.sh",
    "SessionStart": [
      {"matcher": "startup", "script": "hooks/granum-coldstart.sh"},
      {"matcher": "compact", "script": "hooks/granum-reinject.sh"}
    ],
    "PostToolUse": {"matcher": "Edit|Write", "script": "hooks/granum-spec-sync.sh"}
  }
}
